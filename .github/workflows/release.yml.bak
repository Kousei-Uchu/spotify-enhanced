name: Release

on:
  push:
    tags:
      - "v*"

jobs:
  # ── Validate the integration ────────────────────────────────────────────
  validate:
    name: Validate integration
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: pip install homeassistant spotipy

      - name: Validate manifest
        run: |
          python - << 'EOF'
          import json, sys
          with open("custom_components/spotify_enhanced/manifest.json") as f:
              m = json.load(f)
          required = ["domain","name","version","requirements","config_flow","iot_class"]
          missing = [k for k in required if k not in m]
          if missing:
              print(f"manifest.json missing keys: {missing}")
              sys.exit(1)
          print(f"manifest.json OK — version {m['version']}")
          EOF

      - name: Validate strings JSON
        run: |
          python -c "
          import json
          for f in ['custom_components/spotify_enhanced/strings.json',
                    'custom_components/spotify_enhanced/translations/en.json']:
              with open(f) as fh:
                  json.load(fh)
              print(f'{f} OK')
          "

      - name: HACS validation
        uses: hacs/action@main
        with:
          category: integration

  # ── Build and publish release ───────────────────────────────────────────
  release:
    name: Create GitHub Release
    runs-on: ubuntu-latest
    needs: validate
    permissions:
      contents: write

    steps:
      - uses: actions/checkout@v4

      - name: Get version from tag
        id: version
        run: echo "VERSION=${GITHUB_REF#refs/tags/v}" >> $GITHUB_OUTPUT

      - name: Update version in manifest.json
        run: |
          python - << 'EOF'
          import json, os
          v = os.environ["VERSION"]
          path = "custom_components/spotify_enhanced/manifest.json"
          with open(path) as f:
              m = json.load(f)
          m["version"] = v
          with open(path, "w") as f:
              json.dump(m, f, indent=2)
          print(f"Set manifest version to {v}")
          EOF
        env:
          VERSION: ${{ steps.version.outputs.VERSION }}

      - name: Build release ZIP
        run: |
          VERSION=${{ steps.version.outputs.VERSION }}

          # Integration ZIP (what HACS downloads)
          zip -r spotify_enhanced_${VERSION}.zip \
            custom_components/spotify_enhanced/ \
            -x "**/__pycache__/*" -x "**/*.pyc"

          # Frontend card ZIP
          zip -r spotify_enhanced_card_${VERSION}.zip \
            www/spotify-enhanced-card/

          # Full release ZIP (manual install)
          zip -r spotify_enhanced_full_${VERSION}.zip \
            custom_components/spotify_enhanced/ \
            www/spotify-enhanced-card/ \
            docs/ examples/ install.sh \
            -x "**/__pycache__/*" -x "**/*.pyc"

          ls -lh *.zip

      - name: Create release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ github.ref_name }}
          name: Spotify Enhanced ${{ github.ref_name }}
          draft: false
          prerelease: false
          generate_release_notes: true
          files: |
            spotify_enhanced_${{ steps.version.outputs.VERSION }}.zip
            spotify_enhanced_card_${{ steps.version.outputs.VERSION }}.zip
            spotify_enhanced_full_${{ steps.version.outputs.VERSION }}.zip
          body: |
            ## Spotify Enhanced ${{ github.ref_name }}

            ### Installation via HACS
            HACS will automatically download the update. After installing, restart Home Assistant.

            ### Manual Installation
            1. Download `spotify_enhanced_full_${{ steps.version.outputs.VERSION }}.zip`
            2. Extract and run `./install.sh /config`
            3. Restart Home Assistant

            ### Lovelace Card Resource
            Add `/local/spotify-enhanced-card/spotify-enhanced-card.js` as a **JavaScript Module** in
            Settings → Dashboards → Resources (or let the integration auto-register it).
