[Unit]
Description=Spotify Enhanced Colour Extraction Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/path/to/colour-service
ExecStartPre=/usr/bin/npm run build
ExecStart=/usr/bin/node dist/server.js
Restart=always
RestartSec=5
Environment=PORT=5174

[Install]
WantedBy=multi-user.target
